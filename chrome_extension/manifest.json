{
  "manifest_version": 3,
  "name": "AI Scam Shield - Fraud Detection",
  "version": "1.0.0",
  "description": "Real-time AI-powered protection against phishing, fake jobs, and online scams.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
